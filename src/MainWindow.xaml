<Window x:Class="PoE2LevelingCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PoE2LevelingCompanion.ViewModels"
        Title="PoE2 Leveling Companion"
        Width="540" Height="300"
        MinWidth="460" MinHeight="150"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Border Background="#DD1a1a2e" CornerRadius="8" BorderBrush="#44888888" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar (draggable) -->
            <Border Grid.Row="0" Background="#44ffffff" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel Margin="10,6">
                    <TextBlock Text="PoE2 Leveling Companion"
                               Foreground="#cccccc" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#x2699;" Click="EditCheckpoints_Click"
                                Style="{StaticResource WindowButton}" ToolTip="Edit Checkpoints" />
                        <Button Content="&#x2014;" Click="Minimize_Click"
                                Style="{StaticResource WindowButton}" />
                        <Button Content="&#x2715;" Click="Close_Click"
                                Style="{StaticResource WindowButton}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content area: two columns -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>

                <!-- Left column: character info + zone + notifications -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Character info header -->
                    <Border Grid.Row="0" Padding="10,6" Background="#221a1a2e">
                        <StackPanel>
                            <TextBlock Foreground="#e8a735" FontSize="13" FontWeight="Bold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} ({1}) - Level {2}">
                                        <Binding Path="Session.CharacterName" />
                                        <Binding Path="Session.CharacterClass" />
                                        <Binding Path="Session.Level" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="{Binding StatusText}" Foreground="#888888" FontSize="11" />
                        </StackPanel>
                    </Border>

                    <!-- Zone level -->
                    <Border Grid.Row="1" Padding="10,5" Background="#181828"
                            Visibility="{Binding Session.CurrentAreaLevel, Converter={StaticResource ZoneLevelVisibility}}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{Binding Session.CurrentZone}"
                                       Foreground="#aaaaaa" FontSize="12" VerticalAlignment="Center" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Zone Level: " Foreground="#888888" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Session.CurrentAreaLevel}" FontSize="13" FontWeight="Bold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Foreground>
                                        <MultiBinding Converter="{StaticResource LevelDiffBrush}">
                                            <Binding Path="Session.Level" />
                                            <Binding Path="Session.CurrentAreaLevel" />
                                        </MultiBinding>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Notifications list -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding Notifications}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="6,2" Padding="8,6" Background="#33ffffff" CornerRadius="4">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="&#x2715;"
                                                Command="{Binding DataContext.DismissNotificationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource WindowButton}"
                                                VerticalAlignment="Top" Margin="4,0,0,0" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding Message}" Foreground="#e0e0e0"
                                                       FontSize="12" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                       Foreground="#666666" FontSize="10" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty state -->
                    <TextBlock Grid.Row="2" Text="No notifications yet"
                               Foreground="#555555" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding Notifications.Count, Converter={StaticResource EmptyToVisibility}}" />
                </Grid>

                <!-- Separator -->
                <Border Grid.Column="1" Background="#22ffffff" />

                <!-- Right column: splits panel -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Splits header with total run timer -->
                    <Border Grid.Row="0" Padding="8,6" Background="#221a1a2e">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Splits" Foreground="#cccccc" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button DockPanel.Dock="Right" Content="Reset"
                                        Command="{Binding ResetBestTimesCommand}"
                                        Style="{StaticResource WindowButton}"
                                        ToolTip="Reset best times" FontSize="10"
                                        HorizontalAlignment="Right" />
                            </DockPanel>
                            <DockPanel Margin="0,2,0,0">
                                <TextBlock Text="Total:" Foreground="#888888" FontSize="10"
                                           VerticalAlignment="Center" />
                                <TextBlock DockPanel.Dock="Right" Text="{Binding TotalRunElapsed}"
                                           Foreground="#88cc88" FontSize="12" FontWeight="Bold"
                                           FontFamily="Consolas" HorizontalAlignment="Right"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Splits list -->
                    <ListBox Grid.Row="1" x:Name="SplitsListBox"
                             ItemsSource="{Binding Splits}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,3" BorderBrush="#11ffffff" BorderThickness="0,0,0,1">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding DeltaText}"
                                                   Foreground="{Binding Delta, Converter={StaticResource SplitDeltaBrush}}"
                                                   FontSize="11" FontFamily="Consolas"
                                                   Margin="6,0,0,0" VerticalAlignment="Center" />
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding DurationText}"
                                                   Foreground="#cccccc" FontSize="11" FontFamily="Consolas"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ZoneName}" Foreground="#aaaaaa" FontSize="10"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty state for splits -->
                    <TextBlock Grid.Row="1" Text="No splits yet"
                               Foreground="#555555" FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding Splits.Count, Converter={StaticResource EmptyToVisibility}}" />

                    <!-- Current zone timer -->
                    <Border Grid.Row="2" Padding="8,5" Background="#181828"
                            BorderBrush="#22ffffff" BorderThickness="0,1,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" Text="{Binding CurrentZoneElapsed}"
                                       Foreground="#e8a735" FontSize="14" FontWeight="Bold"
                                       FontFamily="Consolas" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Session.CurrentZone}" Foreground="#aaaaaa" FontSize="10"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
