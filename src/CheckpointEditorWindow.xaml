<Window x:Class="PoE2LevelingCompanion.CheckpointEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PoE2LevelingCompanion.ViewModels"
        Title="Checkpoint Editor"
        Width="750" Height="550"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <Window.DataContext>
        <vm:CheckpointEditorViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e8a735" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="EditorTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2a2a3e" />
            <Setter Property="Foreground" Value="#e0e0e0" />
            <Setter Property="BorderBrush" Value="#444466" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="CaretBrush" Value="#e0e0e0" />
        </Style>

        <Style x:Key="EditorComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2a2a3e" />
            <Setter Property="Foreground" Value="#e0e0e0" />
            <Setter Property="BorderBrush" Value="#444466" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style x:Key="EditorCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e0e0e0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#e8a735" />
            <Setter Property="Foreground" Value="#1a1a2e" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f0b845" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="Transparent" BorderBrush="#333355">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#22ffffff" />
                    <Setter Property="Foreground" Value="#aaaaaa" />
                    <Setter Property="Padding" Value="14,6" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}"
                                        BorderBrush="#333355" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0">
                                    <ContentPresenter ContentSource="Header" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#2a2a3e" />
                                        <Setter Property="Foreground" Value="#e8a735" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Zone Checkpoints Tab -->
            <TabItem Header="Zone Checkpoints">
                <Border Background="#2a2a3e" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" Style="{StaticResource EditorTextBox}"
                                 Text="{Binding ZoneSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8" Tag="Search zones..." />

                        <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredZoneEntries}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  Background="Transparent" Foreground="#e0e0e0"
                                  BorderThickness="0" GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#333355"
                                  RowBackground="#2a2a3e" AlternatingRowBackground="#252540"
                                  HeadersVisibility="Column" SelectionMode="Single"
                                  CanUserResizeRows="False">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#1a1a2e" />
                                    <Setter Property="Foreground" Value="#e8a735" />
                                    <Setter Property="Padding" Value="8,6" />
                                    <Setter Property="BorderBrush" Value="#333355" />
                                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Foreground" Value="#e0e0e0" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="4,2" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                                    <ContentPresenter VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding HasCheckpoint, UpdateSourceTrigger=PropertyChanged}" Width="40" />
                                <DataGridTextColumn Header="Act" Binding="{Binding Act}" Width="Auto" IsReadOnly="True" />
                                <DataGridTextColumn Header="Zone" Binding="{Binding ZoneName}" Width="160" IsReadOnly="True" />
                                <DataGridTextColumn Header="Message" Binding="{Binding Message, UpdateSourceTrigger=PropertyChanged}" Width="*">
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="#1a1a2e" />
                                            <Setter Property="Foreground" Value="#e0e0e0" />
                                            <Setter Property="CaretBrush" Value="#e0e0e0" />
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>
                                <DataGridComboBoxColumn Header="Class" Width="120"
                                    SelectedItemBinding="{Binding ClassFilter, UpdateSourceTrigger=PropertyChanged}"
                                    ItemsSource="{Binding Source={x:Static vm:CheckpointEditorViewModel.ClassOptionsStatic}}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Level Checkpoints Tab -->
            <TabItem Header="Level Checkpoints">
                <Border Background="#2a2a3e" Padding="10">
                    <DataGrid ItemsSource="{Binding LevelEntries}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              Background="Transparent" Foreground="#e0e0e0"
                              BorderThickness="0" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#333355"
                              RowBackground="#2a2a3e" AlternatingRowBackground="#252540"
                              HeadersVisibility="Column" SelectionMode="Single"
                              CanUserResizeRows="False">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#1a1a2e" />
                                <Setter Property="Foreground" Value="#e8a735" />
                                <Setter Property="Padding" Value="8,6" />
                                <Setter Property="BorderBrush" Value="#333355" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground" Value="#e0e0e0" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="4,2" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="On" Binding="{Binding HasCheckpoint, UpdateSourceTrigger=PropertyChanged}" Width="40" />
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="60" IsReadOnly="True" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message, UpdateSourceTrigger=PropertyChanged}" Width="*">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="#1a1a2e" />
                                        <Setter Property="Foreground" Value="#e0e0e0" />
                                        <Setter Property="CaretBrush" Value="#e0e0e0" />
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridComboBoxColumn Header="Class" Width="120"
                                SelectedItemBinding="{Binding ClassFilter, UpdateSourceTrigger=PropertyChanged}"
                                ItemsSource="{Binding Source={x:Static vm:CheckpointEditorViewModel.ClassOptionsStatic}}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Bottom bar -->
        <DockPanel Grid.Row="1" Margin="0,10,0,0">
            <Button DockPanel.Dock="Right" Content="Save Checkpoints"
                    Command="{Binding SaveCommand}" Style="{StaticResource ActionButton}" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="#88cc88" FontSize="12"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
        </DockPanel>
    </Grid>
</Window>
